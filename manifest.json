{
  "manifest_version": 3,
  "name": "TabFlow",
  "version": "1.0.0",
  "description": "标签页工作区管理器 — 一键保存/恢复窗口，搜索标签，去重整理",
  "homepage_url": "https://479464887-rgb.github.io/tabflow/",
  "author": {"email": "tulv202900@163.com"},
  "permissions": ["tabs", "tabGroups", "storage", "commands"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TabFlow"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "打开 TabFlow"
    }
  }
}
